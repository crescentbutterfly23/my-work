  {
    "id": "dance-perfumes",
    "title": "Dance Perfumes",
    "category": "Print Design",
    "year": "2023",
    "featured": false,
    "description": "Two dance-inspired fragrances: “Flamenco Dancing Gypsy” and “Bolero Sensuous Step.”",
    "behance": "https://www.behance.net/gallery/177222763/Case-Study-Dance-Perfumes",
    "image": "assets/projects/behance/dance-perfumes.png",
    "blocks": [
      { "type": "text", "style": "lead", "text": "Two dance-inspired fragrances, each translating a dance into an olfactory arc of top, heart, and base notes." },
      { "type": "text", "style": "body", "text": "Flamenco Dancing Gypsy captures the passion and elegance of Flamenco — vibrant top notes for swift footwork, deep heart notes for the emotional storytelling, fiery base notes for the finale. Bolero Sensuous Step, inspired by the intimate Bolero duet, choreographs tender top notes, emotional heart notes, and lingering base notes into an enduring romantic bond." },
      { "type": "image", "width": "full", "image": "https://mir-s3-cdn-cf.behance.net/project_modules/1400_webp/7a8ffa177222763.64d28430190f6.png", "caption": "Flamenco Dancing Gypsy" },
